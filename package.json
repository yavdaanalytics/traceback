{
  "name": "traceback",
  "version": "0.1.0",
  "description": "Semantic debugger MCP server: warm-starts grep/git with cosine-similarity recall over past coding-agent sessions",
  "license": "MIT",
  "type": "module",
  "bin": {
    "traceback": "dist/mcp/index.js",
    "traceback-install-hook": "dist/cli/install-hook.js",
    "traceback-install-global-hook": "dist/cli/install-global-hook.js",
    "traceback-setup": "dist/cli/setup.js",
    "traceback-warmstart": "dist/cli/warm-start.js",
    "traceback-hook-entry": "dist/cli/hook-entry.js",
    "traceback-dashboard": "dist/cli/dashboard.js",
    "traceback-telemetry": "dist/cli/telemetry.js",
    "traceback-metrics": "dist/cli/metrics-collector.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/mcp/index.js",
    "release:sync-plugins": "node scripts/sync-plugin-versions.mjs",
    "release:verify-tag": "node scripts/verify-release-tag.mjs",
    "test": "vitest run",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:e2e": "vitest run tests/e2e",
    "test:regression": "vitest run tests/regression",
    "test:evals": "vitest run tests/evals",
    "bench": "node scripts/bench.mjs",
    "phase1:e2e": "node scripts/phase1-e2e.mjs",
    "test:prompt-capture": "vitest run tests/unit/prompt-capture-fixture.test.ts tests/e2e/prompt-capture.test.ts tests/e2e/prompt-capture-mcp.test.ts tests/integration/warm-start-prompt.test.ts",
    "security:sast": "semgrep --config auto --config p/command-injection src --error",
    "security:audit": "npm audit"
  },
  "dependencies": {
    "@lancedb/lancedb": "^0.13.0",
    "@modelcontextprotocol/sdk": "^1.0.4",
    "fastembed": "^1.14.1",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "typescript": "^5.7.2",
    "vitest": "4.1.9"
  },
  "engines": {
    "node": ">=22.5.0"
  }
}
